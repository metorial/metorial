{
  "name": "@metorial/integrations-root",
  "scripts": {
    "biome:check": "biome check --write .",
    "integrations:cli": "bun packages/cli/src/cli.ts",
    "integrations:validate-pr": "bun scripts/validate-pr-integrations.ts",
    "local-deps:check": "bun scripts/check-package-local-node-modules.ts",
    "local-deps:clean": "bun scripts/check-package-local-node-modules.ts --fix",
    "package-local": "bun scripts/package-local.ts",
    "packages:sync-versions": "bun scripts/update-integration-package-versions.ts",
    "packages:build": "turbo run build --filter=./packages/*",
    "integrations:build:inner": "turbo run build --concurrency=1 --ui=stream --filter=./integrations/* --filter=./test-integrations/*",
    "build:integrations": "bun run packages:build && bun run integrations:build:inner"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "tsup": "^8.5.1",
    "turbo": "^2.5.5",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.2.15"
  },
  "packageManager": "bun@1.2.15",
  "workspaces": [
    "packages/*",
    "integrations/*",
    "test-integrations/*"
  ],
  "dependencies": {
    "@types/bun": "^1.3.12"
  }
}
