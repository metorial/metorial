{
  "name": "@slates/client",
  "version": "1.0.0-rc.12",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**",
    "dist/**",
    "README.md",
    "package.json"
  ],
  "author": "Tobias Herber",
  "license": "FSL 1.1",
  "type": "module",
  "source": "src/index.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.module.js",
    "default": "./dist/index.module.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.module.js",
  "types": "dist/index.d.ts",
  "unpkg": "./dist/index.module.js",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsup --config ../../tsup.packages.config.ts --external async_hooks",
    "typecheck": "tsc --noEmit",
    "biome:check": "biome check --write src"
  },
  "dependencies": {
    "@slates/proto": "1.0.0-rc.11",
    "@slates/provider": "1.0.0-rc.15",
    "@slates/provider-handler": "1.0.0-rc.17"
  },
  "devDependencies": {
    "@slates/tsconfig": "1.0.0-rc.1",
    "typescript": "5.8.2",
    "vitest": "^3.1.2"
  }
}
